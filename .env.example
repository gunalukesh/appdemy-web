# ══════════════════════════════════════════════════════════
# SAMACHEER KALVI LMS — Environment Variables
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════════════

# Supabase (https://supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Razorpay (https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret-here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Samacheer Kalvi LMS

# Video Storage (Supabase Storage is used by default, no extra config needed)
# If using Cloudflare Stream later, add:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_STREAM_TOKEN=
